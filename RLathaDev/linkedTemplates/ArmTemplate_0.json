{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "RLathaDev"
		},
		"AzureBlobStorage1_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'AzureBlobStorage1'"
		},
		"AzureSqlDatabase1_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'AzureSqlDatabase1'"
		},
		"AzureSqlDatabase2_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'AzureSqlDatabase2'"
		},
		"LS_BLOB_BinaryText_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'LS_BLOB_BinaryText'"
		},
		"LS_BLOB_CSV_TO_ADLS_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'LS_BLOB_CSV_TO_ADLS'"
		},
		"LS_Binary_ADLS_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'LS_Binary_ADLS'"
		},
		"LS_Blob_SCD1_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'LS_Blob_SCD1'"
		},
		"LS_Blob_SCDT1_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'LS_Blob_SCDT1'"
		},
		"LS_Multiple_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'LS_Multiple'"
		},
		"LS_Output_CSV_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'LS_Output_CSV'"
		},
		"LS_SCD_ADLS_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'LS_SCD_ADLS'"
		},
		"LS_SCD_BlobSource_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'LS_SCD_BlobSource'"
		},
		"LS_SCd_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'LS_SCd'"
		},
		"LS_SINK_RESTAPI_Parquet_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'LS_SINK_RESTAPI_Parquet'"
		},
		"LS_SINK_RestAPI_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'LS_SINK_RestAPI'"
		},
		"LS_SQL_SCD_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'LS_SQL_SCD'"
		},
		"AzureSqlDatabase1_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "adminlatha.database.windows.net"
		},
		"AzureSqlDatabase1_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "free-sql-db-2969701"
		},
		"AzureSqlDatabase1_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "srlatha"
		},
		"AzureSqlDatabase2_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "adminlatha.database.windows.net"
		},
		"AzureSqlDatabase2_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "free-sql-db-2969701"
		},
		"AzureSqlDatabase2_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "srlatha"
		},
		"LS_Binary_ADLS_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://slathaadlsstorageaccount.dfs.core.windows.net/"
		},
		"LS_Output_CSV_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://slathaadlsstorageaccount.dfs.core.windows.net/"
		},
		"LS_RestService_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://jsonplaceholder.typicode.com/users"
		},
		"LS_SCD_ADLS_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://slathaadlsstorageaccount.dfs.core.windows.net/"
		},
