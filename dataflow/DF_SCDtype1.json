{
	"name": "DF_SCDtype1",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_Source_SCD1",
						"type": "DatasetReference"
					},
					"name": "SourceFromADLS"
				},
				{
					"dataset": {
						"referenceName": "DS_SQL_SCD1",
						"type": "DatasetReference"
					},
					"name": "SourceSQL"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_SQL_SCD1",
						"type": "DatasetReference"
					},
					"name": "UpdatedSink"
				},
				{
					"dataset": {
						"referenceName": "DS_SQL_SCD1",
						"type": "DatasetReference"
					},
					"name": "InsertSink"
				}
			],
			"transformations": [
				{
					"name": "LookupSCD"
				},
				{
					"name": "UpdatedRows"
				},
				{
					"name": "Updated"
				},
				{
					"name": "Insert"
				},
				{
					"name": "AlterRowUpdated"
				},
				{
					"name": "AlterRowInsert"
				}
			],
			"scriptLines": [
				"source(output(",
				"          ID as string,",
				"          Name as string,",
				"          City as string,",
				"          Phone as string,",
				"          Email as string,",
				"          CustomerType as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> SourceFromADLS",
				"source(output(",
				"          Cust_ID as integer,",
				"          Name as string,",
				"          City as string,",
				"          Phone as integer,",
				"          Email as string,",
				"          Segment as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> SourceSQL",
				"SourceFromADLS, SourceSQL lookup(ID == toString(Cust_ID),",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> LookupSCD",
				"LookupSCD split(equals(ID,toString(Cust_ID)),",
				"     disjoint: false) ~> UpdatedRows@(UpdatedRows, InsertRows)",
				"UpdatedRows@UpdatedRows derive(LastUpdate = currentTimestamp()) ~> Updated",
				"UpdatedRows@InsertRows derive(LastUpdate = currentTimestamp()) ~> Insert",
				"Updated alterRow(updateIf(equals(ID, toString(Cust_ID)))) ~> AlterRowUpdated",
				"Insert alterRow(insertIf(isNull(ID))) ~> AlterRowInsert",
				"AlterRowUpdated sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          Cust_ID as integer,",
				"          Name as string,",
				"          City as string,",
				"          Phone as integer,",
				"          Email as string,",
				"          Segment as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> UpdatedSink",
				"AlterRowInsert sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          Cust_ID as integer,",
				"          Name as string,",
				"          City as string,",
				"          Phone as integer,",
				"          Email as string,",
				"          Segment as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> InsertSink"
			]
		}
	}
}