			"type": "string",
			"defaultValue": "adminlatha.database.windows.net"
		},
		"LS_SQL_SCD_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "free-sql-db-2969701"
		},
		"LS_SQL_SCD_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "srlatha"
		}
